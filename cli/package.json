{
  "name": "@horus/cli",
  "version": "0.1.0",
  "description": "CLI for managing the Horus Docker Compose stack",
  "type": "module",
  "bin": {
    "horus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "execa": "^8.0.0",
    "chalk": "^5.0.0",
    "yaml": "^2.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "compose"
  ],
  "keywords": [
    "horus",
    "cli",
    "docker",
    "mcp"
  ],
  "license": "MIT"
}
