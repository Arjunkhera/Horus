# ─────────────────────────────────────────────────────────────────────────────
# Horus — Environment Defaults
# Copy this file to .env (or export variables) before running:
#   cp .env.horus .env
#   docker-compose -f docker-compose.horus.yml up --build
#
# All variables are optional — defaults shown below will be used if unset.
# ─────────────────────────────────────────────────────────────────────────────

# ── Port overrides ────────────────────────────────────────────────────────────
# Uncomment to change host-side port bindings (container ports stay fixed)
# ANVIL_PORT=8100
# VAULT_PORT=8000
# FORGE_PORT=8200

# ── GitHub token ──────────────────────────────────────────────────────────────
# Required if Anvil needs to git-pull the Notes repo from a private remote.
# Leave blank if the Notes repo is local-only or already cloned.
GITHUB_TOKEN=

# ── Anvil settings ────────────────────────────────────────────────────────────
ANVIL_QMD_COLLECTION=anvil
ANVIL_SYNC_INTERVAL=300
ANVIL_DEBOUNCE_SECONDS=5

# ── Vault settings ────────────────────────────────────────────────────────────
QMD_INDEX_NAME=knowledge
VAULT_SYNC_INTERVAL=300
LOG_LEVEL=info
