# ─────────────────────────────────────────────────────────────────────────────
# Horus — Environment Defaults (DEVELOPMENT ONLY)
#
# WARNING: This .env is for development builds (docker-compose up --build).
# For production, use `horus setup` which generates ~/Horus/.env automatically.
# Do NOT leave a stale HORUS_DATA_PATH here — Docker will auto-create
# directories for bind mounts, producing ghost data folders on the host.
#
# HORUS_DATA_PATH is required — must be set before running docker-compose.
# Other variables are optional — defaults shown below will be used if unset.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data directory (REQUIRED) ─────────────────────────────────────────────────
# Absolute path where Horus stores cloned repositories and workspace data.
# Must be an absolute path — Docker does NOT expand ~ or ${HOME}.
# Set before running: export HORUS_DATA_PATH="${HOME}/Horus/data"
#                     mkdir -p "${HORUS_DATA_PATH}"
HORUS_DATA_PATH=

# ── Host repos directory (REQUIRED for repo indexing) ─────────────────────────
# Absolute path on the host where your git repos live.
# Mounted read-only into Forge at /data/repos so the repo scanner can index them.
# Example: HOST_REPOS_PATH=/Users/yourname/Desktop/Repositories
HOST_REPOS_PATH=

# ── Forge scan paths (auto-generated — do not edit manually) ──────────────────
# Set via: horus config set host-repos-extra-scan-dirs <comma-separated-dirs>
# Colon-separated container paths passed to Forge. Defaults to /data/repos.
# Example with subdirectory grouping: FORGE_SCAN_PATHS=/data/repos:/data/repos/ArjunKhera
FORGE_SCAN_PATHS=/data/repos

# ── Port overrides ────────────────────────────────────────────────────────────
# Uncomment to change host-side port bindings (container ports stay fixed)
# ANVIL_PORT=8100
# VAULT_PORT=8000
# VAULT_MCP_PORT=8300
# FORGE_PORT=8200
# TYPESENSE_PORT=8108

# ── GitHub token ──────────────────────────────────────────────────────────────
# Used by all three services (Anvil, Vault, Forge) for cloning/pulling private repos.
# Required if any repos are private. Leave blank for public repos only.
GITHUB_TOKEN=

# ── Repository URLs ───────────────────────────────────────────────────────────
# These URLs are used on first boot to clone repos into HORUS_DATA_PATH.
# Services will skip cloning if the directories already exist.
#
# IMPORTANT: Use HTTPS URLs only — e.g., https://github.com/<owner>/<repo>
# Container services (Vault, Anvil, Forge) do not have SSH keys mounted.
# SSH URLs (git@github.com:...) will fail at runtime inside Docker/Podman.
# Set GITHUB_TOKEN (above) for private repos.
#
# Anvil: Notes repo (required if starting fresh)
ANVIL_REPO_URL=

# Vault: Knowledge base repo (defaults to arkhera's public repo)
VAULT_KNOWLEDGE_REPO_URL=https://github.com/arkhera/knowledge-base

# Forge: Registry repo (defaults to arkhera's public repo)
FORGE_REGISTRY_REPO_URL=https://github.com/arkhera/Forge-Registry

# ── Anvil settings ────────────────────────────────────────────────────────────
ANVIL_SYNC_INTERVAL=300
ANVIL_DEBOUNCE_SECONDS=5

# ── Vault settings ────────────────────────────────────────────────────────────
VAULT_SYNC_INTERVAL=300
LOG_LEVEL=info

# ── Typesense settings ──────────────────────────────────────────────────────
# Typesense is the unified search engine for all Horus services.
# All services (Anvil, Vault, Forge) index into a shared `horus_documents`
# collection. The defaults below match the docker-compose.yml configuration.
# TYPESENSE_HOST=localhost
# TYPESENSE_PORT=8108
# TYPESENSE_API_KEY=horus-local-key
# TYPESENSE_PROTOCOL=http
