{
  "name": "@arkhera30/cli",
  "version": "0.3.0",
  "description": "CLI for managing the Horus AI development stack",
  "type": "module",
  "bin": {
    "horus": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.0.0",
    "commander": "^12.0.0",
    "execa": "^8.0.0",
    "ora": "^8.0.0",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "compose"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Arjunkhera/Horus.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Arjunkhera/Horus#readme",
  "bugs": {
    "url": "https://github.com/Arjunkhera/Horus/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "horus",
    "cli",
    "docker",
    "mcp",
    "claude",
    "ai"
  ],
  "license": "MIT"
}
